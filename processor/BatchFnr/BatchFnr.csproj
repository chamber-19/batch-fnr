<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>BatchFnr</RootNamespace>
    <AssemblyName>BatchFnr</AssemblyName>
    <!-- Sidecar must run on the same CLR as AutoCAD; do not self-contain. -->
    <SelfContained>false</SelfContained>
    <InvariantGlobalization>true</InvariantGlobalization>
    <!--
      AutoCAD 2026's managed DLLs reference newer BCL versions (Microsoft.VisualBasic
      10.1.0.0, System.Drawing 8.0.0.0, WindowsBase 8.0.0.0) than the net8.0 reference
      assemblies advertise. The CLR resolves them correctly at runtime via the .NET 8
      shared framework, so the MSB3277 conflicts are noise. Downgrade to a build
      message here so real regressions stay visible.
    -->
    <MSBuildWarningsAsMessages>$(MSBuildWarningsAsMessages);MSB3277</MSBuildWarningsAsMessages>
  </PropertyGroup>

  <ItemGroup>
    <!--
      Private=False is mandatory. accoremgd/acdbmgd ship with AutoCAD; copying
      them to our output directory triggers "mixed-mode assembly" / version
      conflicts the moment AutoCAD's own copies load alongside ours.
    -->
    <Reference Include="accoremgd">
      <HintPath>$(AcadDir)\accoremgd.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="acdbmgd">
      <HintPath>$(AcadDir)\acdbmgd.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>

</Project>
