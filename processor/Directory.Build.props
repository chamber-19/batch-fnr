<Project>
  <PropertyGroup>
    <!--
      Preferred AutoCAD version. Override with -p:AutoCadVersion=2025 etc.
      When AcadDir is not set explicitly, the detection ladder tries this
      version first before falling back through 2027 → 2026 → 2025.
    -->
    <AutoCadVersion Condition="'$(AutoCadVersion)' == ''">2027</AutoCadVersion>
  </PropertyGroup>

  <PropertyGroup>
    <!--
      AcadDir is pinned to AutoCAD 2027. Override at build time if needed:
        dotnet build -p:AcadDir="C:\Program Files\Autodesk\AutoCAD 2028"
      The Autodesk references are marked Private=False so they are NOT copied to
      the output directory; doing so causes assembly version conflicts at runtime.
    -->
    <AcadDir Condition="'$(AcadDir)' == ''">C:\Program Files\Autodesk\AutoCAD 2027</AcadDir>
  </PropertyGroup>
</Project>
